# ============================================================
# Namo Core — Runtime Configuration Example
# ============================================================

NAMO_ENV=development
NAMO_API_HOST=127.0.0.1
NAMO_API_PORT=8000
NAMO_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- GCP Configuration ---
GOOGLE_CLOUD_PROJECT=namo-classroom
GOOGLE_APPLICATION_CREDENTIALS=C:\path\to\your\namo-sa-key.json

# --- Secrets ---
# Secrets (e.g. JWT secret, DB password, LLM API keys) are now loaded 
# from Google Cloud Secret Manager via gcp_secrets.py for security.
# They are NOT stored in .env anymore.

# --- LLM Reasoning ---
NAMO_REASONING_PROVIDER=mock
NAMO_REASONING_MODEL=namo-recovered-demo
NAMO_REASONING_TIMEOUT_SECONDS=30
NAMO_REASONING_ALLOW_MOCK_FALLBACK=true

# --- Speech (STT) ---
NAMO_SPEECH_PROVIDER=mock
NAMO_SPEECH_MODEL=tiny
NAMO_SPEECH_LANGUAGE=th
NAMO_SPEECH_CHUNK_MS=30
NAMO_SPEECH_SILENCE_MS=600
NAMO_SPEECH_LISTEN_TIMEOUT_SECONDS=0.35
NAMO_SPEECH_MAX_UTTERANCE_SECONDS=8.0
NAMO_SPEECH_VAD_THRESHOLD=0.015
